<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.scenes.IngredientsOverviewCtrl">
   <bottom>
      <HBox alignment="CENTER" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="14.0" prefWidth="84.0" style="-fx-spacing: 40;" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="addIngredientButton" mnemonicParsing="false" onAction="#addGlobalIngredient" text="+" />
                  <Button fx:id="deleteIngredientButton" mnemonicParsing="false" onAction="#deleteGlobalIngredient" prefWidth="24.8" text="-" />
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#goBackToRecipeOverview" text="Back" />
                  <Button mnemonicParsing="false" onAction="#refresh" text="Refresh" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" />
         </padding>
      </HBox>
   </bottom>
   <center>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tableIngredients" prefHeight="338.0" prefWidth="571.0" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colName" minWidth="0.0" prefWidth="435.20001220703125" text="Ingredient Name" />
                  <TableColumn fx:id="colNumOfRecipes" prefWidth="133.5999755859375" text="# of Recipes It's Used In" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
