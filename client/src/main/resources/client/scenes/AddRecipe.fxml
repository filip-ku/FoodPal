      <StackPane>
         <children>
            <AnchorPane maxHeight="200.0" maxWidth="470.0" minHeight="200.0" minWidth="470.0" prefHeight="200.0" prefWidth="470.0">
               <children>
                  <Button layoutX="419.0" layoutY="159.0" mnemonicParsing="false" onAction="#okButton" text="Ok" />
                  <Button layoutX="350.0" layoutY="159.0" mnemonicParsing="false" onAction="#cancelButton" text="Cancel" />
                  <TextField fx:id="title" layoutX="175.0" layoutY="59.0" prefHeight="26.0" prefWidth="164.0" />
                  <Label layoutX="90.0" layoutY="64.0" text="Recipe Name" />
                  <ComboBox fx:id="languageComboBox" layoutX="175.0" layoutY="105.0" prefHeight="26.0" prefWidth="164.0" />
